# Copy to `.env` in this folder for local dev.
# RN accepts either EXPO_PUBLIC_* or the same names used by web/Capacitor CI:
# SUPABASE_URL + SUPABASE_PUBLISHABLE_KEY (legacy SUPABASE_ANON_KEY also supported).

EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_PUBLISHABLE_KEY=YOUR_SUPABASE_ANON_KEY
EXPO_PUBLIC_LLM_ENDPOINT=
LLM_ENDPOINT=
